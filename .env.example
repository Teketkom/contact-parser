# ──────────────────────────────────────────────────────────────────────────────
# Contact Information Parser — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Provider: openai | anthropic | ollama | deepseek
LLM_PROVIDER=openai

# API key for the chosen LLM provider
LLM_API_KEY=sk-your-api-key-here

# Model to use for extraction
# OpenAI:    gpt-4o-mini | gpt-4o | gpt-3.5-turbo
# Anthropic: claude-3-haiku-20240307 | claude-3-5-sonnet-20241022
# DeepSeek:  deepseek-chat
LLM_MODEL=gpt-4o-mini

# Optional: custom base URL (for Ollama, Azure OpenAI, proxies, etc.)
LLM_BASE_URL=

# ── Application Settings ───────────────────────────────────────────────────────
# Environment: development | production
APP_ENV=production

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Crawler Settings ──────────────────────────────────────────────────────────
# Number of sites to process in parallel
MAX_CONCURRENT_CRAWLERS=5

# Seconds to wait for a single page load before timeout
CRAWL_TIMEOUT_SECONDS=30

# Maximum pages to visit per domain (beyond the main page)
MAX_PAGES_PER_SITE=10

# Respect robots.txt: true | false
RESPECT_ROBOTS_TXT=true

# Delay between requests to the same domain (ms)
REQUEST_DELAY_MS=500

# ── Storage ───────────────────────────────────────────────────────────────────
# SQLite (default) or PostgreSQL
DATABASE_URL=sqlite:////app/data/contact_parser.db
# DATABASE_URL=postgresql://user:password@localhost:5432/contact_parser

# Directory for Excel result files
RESULTS_DIR=./results

# Directory for task log files
LOGS_DIR=./logs

# ── Port Configuration ────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-secure-random-string

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
